  }

  .component-tooltip p:last-child {
    margin-bottom: 0;
  }

  .component-tooltip strong {
    color: rgba(255, 255, 255, 0.9);
  }

  .component-info-btn:hover + .component-tooltip,
  .component-tooltip:hover {
    display: block;
  }

  .result-badge {
    padding: 0.15rem 0.5rem;
    font-family: var(--font-mono);
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border: 1px solid;
  }

  .verify-address-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
    padding: 0.5rem 0.75rem;
    background: rgba(134, 239, 172, 0.06);
    border: 1px solid rgba(134, 239, 172, 0.15);
  }
</style>

<script>
  import { signRequest } from "@slicekit/erc8128";
  import { createPublicClient, http } from "viem";
  import { mainnet } from "viem/chains";

  declare global {
    interface Window {
      ethereum?: {
        request: (args: { method: string; params?: unknown[] }) => Promise<any>;
        isPorto?: boolean;
      };
    }
  }

  const methodInput = document.getElementById("methodInput") as HTMLSelectElement;
  const pathInput = document.getElementById("pathInput") as HTMLInputElement;
  const bodyInput = document.getElementById("bodyInput") as HTMLTextAreaElement;
  const bodyBlock = document.getElementById("bodyBlock") as HTMLLabelElement;
  const signatureBasePreview = document.getElementById("signatureBasePreview") as HTMLPreElement;
  const signedHeaders = document.getElementById("signedHeaders") as HTMLPreElement;
  const verificationResult = document.getElementById("verificationResult") as HTMLPreElement;
  const connectWalletBtn = document.getElementById("connectWalletBtn") as HTMLButtonElement;
  const signRequestBtn = document.getElementById("signRequestBtn") as HTMLButtonElement;
  const resetBtn = document.getElementById("resetBtn") as HTMLButtonElement;
  const copyCurlBtn = document.getElementById("copyCurlBtn") as HTMLButtonElement;
  const ttlInput = document.getElementById("ttlInput") as HTMLInputElement;
  const portoStatus = document.getElementById("portoStatus") as HTMLParagraphElement;
  const signTimingEl = document.getElementById("signTiming") as HTMLSpanElement;
  const verifyTimingEl = document.getElementById("verifyTiming") as HTMLSpanElement;
  const verifyLabels = document.getElementById("verifyLabels") as HTMLDivElement;
  const bindingLabel = document.getElementById("bindingLabel") as HTMLSpanElement;
  const replayLabel = document.getElementById("replayLabel") as HTMLSpanElement;
  const verifyAddressBar = document.getElementById("verifyAddressBar") as HTMLDivElement;
  const verifyEnsName = document.getElementById("verifyEnsName") as HTMLSpanElement;
  const verifyAddress = document.getElementById("verifyAddress") as HTMLSpanElement;
  const toggleSignedHeaders = document.getElementById("toggleSignedHeaders") as HTMLButtonElement;
  const toggleVerifyResult = document.getElementById("toggleVerifyResult") as HTMLButtonElement;

  const defaultBody = `{
  "action": "mint",
  "tokenId": 42
}`;

  const ensClient = createPublicClient({ chain: mainnet, transport: http(`https://eth-mainnet.g.alchemy.com/v2/${import.meta.env.PUBLIC_ALCHEMY_KEY}`) });
  const ensCache = new Map<string, string | null>();

  async function resolveEns(address: string): Promise<string | null> {
    const cached = ensCache.get(address.toLowerCase());
    if (cached !== undefined) return cached;
    try {
      const name = await ensClient.getEnsName({ address: address as `0x${string}` });
      ensCache.set(address.toLowerCase(), name);
      return name;
    } catch {
      ensCache.set(address.toLowerCase(), null);
      return null;
    }
  }

  let connectedAddress = "";
  let lastSignedRequest: Request | null = null;
  let currentNonce = crypto.randomUUID().replaceAll("-", "").slice(0, 16);

  bodyInput.value = defaultBody;

  function selectedComponents() {
    return Array.from(document.querySelectorAll<HTMLInputElement>(".component-checkbox:checked")).map((el) => el.value);
  }

  function normalizePath(rawPath: string) {
    const trimmed = rawPath.trim();
    if (!trimmed) return "/verify";
    return trimmed.startsWith("/") ? trimmed : `/${trimmed}`;
  }

  function toHex(bytes: Uint8Array) {
    return `0x${Array.from(bytes).map((b) => b.toString(16).padStart(2, "0")).join("")}`;
  }

  async function sha256Base64(text: string) {
    const digest = await crypto.subtle.digest("SHA-256", new TextEncoder().encode(text || ""));
    let binary = "";
    new Uint8Array(digest).forEach((byte) => {
      binary += String.fromCharCode(byte);
    });
    return btoa(binary);
  }

  function escapeHtml(str: string) {
    return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
  }

  function updateBodyVisibility() {
    bodyBlock.style.display = methodInput.value.toUpperCase() === "GET" ? "none" : "";
  }

  async function buildSignatureBasePreview() {
    const method = methodInput.value.toUpperCase();
    const path = normalizePath(pathInput.value);
    const body = bodyInput.value;
    const components = selectedComponents();
    const lines: string[] = [];
    const allComponents: string[] = [];

    const authority = "erc8128.org";
    lines.push(`<span style="color:#86efac">"@authority": ${authority}</span>`);
    allComponents.push("@authority");

    if (components.includes("@method")) {
      lines.push(`<span style="color:#86efac">"@method": ${method}</span>`);
      allComponents.push("@method");
    }

    if (components.includes("@path")) {
      lines.push(`<span style="color:#86efac">"@path": ${path}</span>`);
      allComponents.push("@path");
    }

    const verifyUrl = `${window.location.origin}${path}`;
    const urlObj = new URL(verifyUrl);
    if (urlObj.search) {
      lines.push(`<span style="color:#86efac">"@query": ${urlObj.search}</span>`);
      allComponents.push("@query");
    }

    if (components.includes("content-digest") && method !== "GET" && body.length > 0) {
      const bodyDigest = await sha256Base64(body);
      lines.push(`<span style="color:#c4b5fd">"content-digest": sha-256=:${bodyDigest}:</span>`);
      allComponents.push("content-digest");
    }

    let chainId = 1;
    try {
      if (window.ethereum && connectedAddress) {
        chainId = Number.parseInt(await window.ethereum.request({ method: "eth_chainId" }), 16) || 1;
      }
    } catch {}

    const ttl = Number.parseInt(ttlInput.value, 10) || 60;
    const now = Math.floor(Date.now() / 1000);
    const expires = now + ttl;
    let paramsStr = `;created=${now};expires=${expires}`;
    paramsStr += `;nonce="${currentNonce}"`;
    paramsStr += `;keyid="erc8128:${chainId}:${connectedAddress || "0x..."}"`;

    lines.push(`<span style="color:rgba(255,255,255,0.35)">"@signature-params": (${allComponents.map((x) => `"${x}"`).join(" ")})${paramsStr}</span>`);

    signatureBasePreview.innerHTML = lines.join("\n");
  }

  async function connectWallet() {
    if (!window.ethereum) {
      verificationResult.textContent = "No injected provider found. Install MetaMask/Rabby/Porto-enabled wallet.";
      return;
    }

    try {
      const accounts = await window.ethereum.request({ method: "eth_requestAccounts" });
      connectedAddress = accounts?.[0] || "";
      connectWalletBtn.textContent = connectedAddress
        ? `${connectedAddress.slice(0, 6)}...${connectedAddress.slice(-4)} [WEB3]`
        : "CONNECT WALLET [WEB3]";

      if (window.ethereum.isPorto) {
        portoStatus.style.display = "";
      }

      await buildSignatureBasePreview();
    } catch (error) {
      verificationResult.textContent = `Wallet connection rejected: ${(error as Error)?.message || "Unknown error"}`;
    }
  }

  async function signAndVerify() {
    if (!connectedAddress) {
      await connectWallet();
      if (!connectedAddress) return;
    }

    const method = methodInput.value.toUpperCase();
    const body = bodyInput.value;
    const path = normalizePath(pathInput.value);
    const signUrl = `https://erc8128.org${path}`;
    const fetchUrl = `${window.location.origin}${path}`;
    const allSelected = selectedComponents();
    const includeNonce = allSelected.includes("nonce");
    const hasBody = method !== "GET" && body.length > 0;
    const components = allSelected
      .filter((c) => c !== "nonce")
      .filter((c) => !(c === "content-digest" && !hasBody));

    const ttl = Number.parseInt(ttlInput.value, 10) || 60;

    let walletWaitMs = 0;
    const signer = {
      address: connectedAddress as `0x${string}`,
      chainId: Number.parseInt(await window.ethereum!.request({ method: "eth_chainId" }), 16) || 1,
      signMessage: async (message: Uint8Array) => {
        const messageHex = toHex(message);
        const t0 = performance.now();
        const sig = await window.ethereum!.request({
          method: "personal_sign",
          params: [messageHex, connectedAddress]
        }) as `0x${string}`;
        walletWaitMs = performance.now() - t0;
        return sig;
      }
    };

    try {
      const includeContentDigest = components.includes("content-digest");
      const requestHeaders: Record<string, string> = {};
      
      // Only include content-type when content-digest is selected AND we have a body
      if (includeContentDigest && hasBody) {
        requestHeaders["content-type"] = "application/json";
      }

      const signStart = performance.now();
      const signed = await signRequest(
        signUrl,
        {
          method,
          headers: requestHeaders,
          body: hasBody ? body : undefined,
        },
        signer,
        {
          binding: "class-bound",
          replay: includeNonce ? "non-replayable" : "replayable",
          nonce: includeNonce ? currentNonce : undefined,
          ttlSeconds: ttl,
          components,
        }
      );
      const signMs = Math.round((performance.now() - signStart - walletWaitMs) * 10) / 10;
      signTimingEl.textContent = `${signMs}ms`;

      lastSignedRequest = signed;

      const headerLines: string[] = [];
      signed.headers.forEach((value, key) => {
        headerLines.push(`<span style="color:#67e8f9">${escapeHtml(key)}:</span> ${escapeHtml(value)}`);
      });
      signedHeaders.innerHTML = headerLines.join("\n");

      const response = await fetch(fetchUrl, {
        method: signed.method,
        headers: signed.headers,
        body: hasBody ? body : undefined,
      });

      let payload: any = null;
      try {
        payload = await response.json();
      } catch {
        payload = { ok: response.ok, status: response.status, message: await response.text() };
      }

      if (payload?.verifyMs != null) {
        verifyTimingEl.textContent = `${Math.round(payload.verifyMs)}ms`;
      } else {
        verifyTimingEl.textContent = "";
      }

      if (payload?.ok) {
        verifyLabels.style.display = "";

        const isRequestBound = payload.binding === "request-bound";
        bindingLabel.textContent = isRequestBound ? "REQUEST-BOUND" : "CLASS-BOUND";
        bindingLabel.style.color = isRequestBound ? "#86efac" : "#fcd34d";
        bindingLabel.style.borderColor = isRequestBound ? "#86efac" : "#fcd34d";

        const isReplayable = payload.replayable;
        replayLabel.textContent = isReplayable ? "REPLAYABLE" : "NON-REPLAYABLE";
        replayLabel.style.color = isReplayable ? "rgba(255,255,255,0.4)" : "#67e8f9";
        replayLabel.style.borderColor = isReplayable ? "rgba(255,255,255,0.2)" : "#67e8f9";

        const shortAddr = `${payload.address.slice(0, 6)}...${payload.address.slice(-4)}`;
        verifyEnsName.style.display = "none";
        verifyEnsName.textContent = "";
        verifyAddress.textContent = shortAddr;
        verifyAddress.className = "font-mono text-[12px] text-[#86efac]";
        verifyAddressBar.style.display = "";

        resolveEns(payload.address).then((ensName) => {
          if (ensName) {
            verifyEnsName.textContent = ensName;
            verifyEnsName.style.display = "";
            verifyAddress.className = "font-mono text-[10px] text-white/35";
          }
        });
      } else {
        verifyLabels.style.display = "none";
        verifyAddressBar.style.display = "none";
      }

      const displayPayload = { ...payload };
      delete displayPayload.verifyMs;
      verificationResult.textContent = JSON.stringify(displayPayload, null, 2);

      currentNonce = crypto.randomUUID().replaceAll("-", "").slice(0, 16);
      await buildSignatureBasePreview();
    } catch (error) {
      verificationResult.textContent = `Signing failed: ${(error as Error)?.message || "Unknown error"}`;
    }
  }

  async function copyCurl() {
    if (!lastSignedRequest) {
      verificationResult.textContent = "Sign a request first, then copy as cURL.";
      return;
    }

    const method = methodInput.value.toUpperCase();
    const path = normalizePath(pathInput.value);
    const body = bodyInput.value.replaceAll("'", "'\\''");
    const headers: string[] = [];

    lastSignedRequest!.headers.forEach((value, key) => {
      headers.push(`-H '${key}: ${value.replaceAll("'", "'\\''")}'`);
    });

    const curl = [
      `curl -X ${method} '${window.location.origin}${path}'`,
      ...headers,
      method === "GET" || method === "DELETE" ? "" : `--data '${body}'`
    ]
      .filter(Boolean)
      .join(" \\\n  ");

    await navigator.clipboard.writeText(curl);
    const original = copyCurlBtn.textContent;
    copyCurlBtn.textContent = "Copied";
    setTimeout(() => {
      copyCurlBtn.textContent = original;
    }, 1200);
  }

  function resetAll() {
    methodInput.value = "POST";
    pathInput.value = "/verify";
    bodyInput.value = defaultBody;
    ttlInput.value = "60";
    document.querySelectorAll<HTMLInputElement>(".component-checkbox").forEach((checkbox) => {
      checkbox.checked = true;
    });
    signedHeaders.textContent = "Sign the request to generate headers.";
    verificationResult.textContent = "Not sent yet.";
    signTimingEl.textContent = "";
    verifyTimingEl.textContent = "";
    verifyLabels.style.display = "none";
    verifyAddressBar.style.display = "none";
    currentNonce = crypto.randomUUID().replaceAll("-", "").slice(0, 16);
    lastSignedRequest = null;
    updateBodyVisibility();
    buildSignatureBasePreview();
  }

  function setupToggle(preEl: HTMLPreElement, btnEl: HTMLButtonElement) {
    let expanded = false;
    const checkOverflow = () => {
      const isOverflowing = preEl.scrollHeight > preEl.clientHeight;
      btnEl.style.display = isOverflowing ? "" : "none";
    };

    btnEl.addEventListener("click", () => {
      expanded = !expanded;
      if (expanded) {
        preEl.style.maxHeight = "none";
        preEl.style.overflowY = "auto";
        btnEl.textContent = "Show less ▲";
      } else {
        preEl.style.maxHeight = "12rem";
        preEl.style.overflowY = "hidden";
        btnEl.textContent = "Show more ▼";
      }
    });

    // Check overflow on content change
    const observer = new MutationObserver(checkOverflow);
    observer.observe(preEl, { childList: true, subtree: true, characterData: true });
    checkOverflow();
  }

  setupToggle(signedHeaders, toggleSignedHeaders);
  setupToggle(verificationResult, toggleVerifyResult);

  connectWalletBtn?.addEventListener("click", connectWallet);
  signRequestBtn?.addEventListener("click", signAndVerify);
  resetBtn?.addEventListener("click", resetAll);
  copyCurlBtn?.addEventListener("click", copyCurl);

  methodInput?.addEventListener("change", () => {
    updateBodyVisibility();
    buildSignatureBasePreview();
  });

  [pathInput, bodyInput].forEach((el) => {
    el?.addEventListener("input", buildSignatureBasePreview);
  });

  ttlInput?.addEventListener("input", buildSignatureBasePreview);

  document.querySelectorAll(".component-checkbox").forEach((el) => {
    el.addEventListener("change", buildSignatureBasePreview);
  });

  updateBodyVisibility();
  buildSignatureBasePreview();
</script>
