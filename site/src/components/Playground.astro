<section class="border-b border-white/15 px-6 py-14 md:px-10 lg:px-14" id="playground">
  <div class="mb-8 flex flex-col gap-5 md:flex-row md:items-start md:justify-between">
    <div>
      <h2 class="text-4xl font-extrabold uppercase tracking-[-0.03em]">PLAYGROUND</h2>
      <p class="mt-2 text-xs uppercase tracking-[0.25em] text-white/55">
        SIGN AND VERIFY AN HTTP REQUEST WITH YOUR ETHEREUM WALLET
      </p>
      <p class="mt-3 max-w-xl font-mono text-sm leading-relaxed text-white/50">
        Test ERC-8128 HTTP signatures in real time. Compose a request, select signature components, and sign with your Ethereum wallet — the server verifies instantly. No backend, no API keys.
      </p>
    </div>

    <button
      id="connectWalletBtn"
      class="border border-white/15 px-5 py-3 font-mono text-xs uppercase tracking-[0.12em] text-white transition-colors duration-200 hover:bg-white hover:text-black"
      type="button"
    >
      CONNECT WALLET [WEB3]
    </button>
  </div>

  <div class="grid gap-0 border border-white/15 lg:grid-cols-[minmax(0,0.42fr)_minmax(0,0.58fr)]">
    <div class="border-b border-white/15 p-4 md:p-6 lg:border-b-0 lg:border-r lg:border-white/15">
      <div class="mb-5">
        <p class="font-mono text-xs uppercase tracking-[0.12em] text-white/55">&gt; 01 // COMPOSE REQUEST</p>
      </div>

      <div class="mb-5 grid gap-4 md:grid-cols-[140px_1fr]">
        <label class="block">
          <span class="mb-2 block font-mono text-[11px] uppercase tracking-[0.18em] text-white/45">Method</span>
          <select id="methodInput" class="playground-field h-11 w-full">
            <option>GET</option>
            <option selected>POST</option>
            <option>PUT</option>
            <option>DELETE</option>
          </select>
        </label>

        <label class="block">
          <span class="mb-2 block font-mono text-[11px] uppercase tracking-[0.18em] text-white/45">Path</span>
          <input id="pathInput" class="playground-field playground-field-disabled h-11 w-full" type="text" value="/verify" disabled />
        </label>
      </div>

      <label id="bodyBlock" class="mb-9 block">
        <span class="mb-2 block font-mono text-[11px] uppercase tracking-[0.18em] text-white/45">Body (JSON)</span>
        <textarea id="bodyInput" class="playground-field min-h-44 w-full resize-y" spellcheck="false"></textarea>
      </label>

      <div class="mb-4 flex items-center justify-between">
        <p class="font-mono text-xs uppercase tracking-[0.12em] text-white/55">&gt; 02 // SIGNATURE COMPONENTS</p>
        <button id="resetBtn" class="font-mono text-[11px] uppercase tracking-[0.15em] text-white/45 transition-colors hover:text-white" type="button">Reset</button>
      </div>

      <div class="relative mb-8 border border-white/15 p-3">
        <div class="grid grid-cols-1 gap-2 md:grid-cols-2">
          <label class="component-chip text-[#86efac]">
            <input class="component-checkbox" type="checkbox" value="@method" checked />
            <span>@method</span>
          </label>
          <label class="component-chip text-[#86efac]">
            <input class="component-checkbox" type="checkbox" value="@path" checked />
            <span>@path</span>
          </label>
          <label class="component-chip text-[#c4b5fd]">
            <input class="component-checkbox" type="checkbox" value="content-digest" checked />
            <span>content-digest</span>
          </label>
          <label class="component-chip text-[#67e8f9]">
            <input class="component-checkbox" type="checkbox" value="nonce" checked />
            <span>nonce</span>
          </label>
        </div>

        <div class="mt-3 flex items-center justify-between border-t border-white/10 pt-3">
          <label class="flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.12em] text-white/45">
            <span>TTL</span>
            <input id="ttlInput" class="ttl-input" type="number" min="1" max="3600" value="60" />
            <span>sec</span>
          </label>

          <div class="relative">
            <button id="componentInfo" class="component-info-btn" type="button">?</button>
            <div id="componentTooltip" class="component-tooltip">
              <p><strong>@authority</strong> &mdash; Prevents use on a different server (always included)</p>
              <p><strong>@method</strong> &mdash; Prevents HTTP method tampering (e.g. GET&rarr;POST)</p>
              <p><strong>@path</strong> &mdash; Binds signature to a specific endpoint</p>
              <p><strong>@query</strong> &mdash; Prevents query parameter tampering (auto-included)</p>
              <p><strong>content-digest</strong> &mdash; SHA-256 hash ensuring body integrity</p>
              <p><strong>nonce</strong> &mdash; Prevents replay attacks (makes each request unique)</p>
              <p><strong>expires</strong> &mdash; Time window for signature validity (TTL)</p>
            </div>
          </div>
        </div>
      </div>

      <div class="flex flex-col gap-3">
        <button
          id="signRequestBtn"
          class="h-12 w-full border border-[#67e8f9] bg-transparent font-mono text-sm font-semibold uppercase tracking-[0.12em] text-[#67e8f9] transition-colors duration-200 hover:bg-[#67e8f9] hover:text-black"
          type="button"
        >
          SIGN REQUEST
        </button>
        <p id="portoStatus" class="text-center font-mono text-[11px] uppercase tracking-[0.18em] text-white/45" style="display:none">PORTO: AUTO-APPROVE ENABLED</p>
      </div>
    </div>

    <div class="p-4 md:p-6">
      <div class="mb-3">
        <p class="font-mono text-xs uppercase tracking-[0.12em] text-white/55">&gt; 03 // SIGNATURE BASE PREVIEW</p>
      </div>

      <div class="relative mb-6">
        <pre id="signatureBasePreview" class="overflow-x-auto border border-white/15 bg-white/5 p-4 font-mono text-[13px] leading-7 text-white/70"></pre>
        <span class="absolute right-3 top-3 border border-white/15 px-2 py-1 font-mono text-[10px] uppercase tracking-[0.16em] text-white/40">RFC 9421</span>
      </div>

      <div class="mb-6 border border-white/15 p-4">
        <div class="mb-2 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <p class="font-mono text-xs uppercase tracking-[0.12em] text-white/55">&gt; 04 // SIGNED HEADERS</p>
            <span id="signTiming" class="font-mono text-[10px] text-white/30"></span>
          </div>
          <button id="copyCurlBtn" class="font-mono text-[11px] uppercase tracking-[0.14em] text-white/50 transition-colors hover:text-white" type="button">
            Copy as cURL
          </button>
        </div>
        <div class="relative">
          <pre id="signedHeaders" class="max-h-48 overflow-x-auto overflow-y-hidden bg-white/5 p-3 font-mono text-[12px] leading-6 text-white/55 transition-all duration-300">Sign the request to generate headers.</pre>
          <button id="toggleSignedHeaders" class="mt-2 w-full font-mono text-[11px] uppercase tracking-[0.15em] text-white/40 transition-colors hover:text-white/70" type="button" style="display:none">
            Show more ▼
          </button>
        </div>
      </div>

      <div class="border border-white/15 p-4">
        <div class="mb-2 flex items-center justify-between">
          <div class="flex items-center gap-3">
            <p class="font-mono text-xs uppercase tracking-[0.12em] text-white/55">&gt; 05 // VERIFICATION RESULT</p>
            <span id="verifyTiming" class="font-mono text-[10px] text-white/30"></span>
          </div>
          <div id="verifyLabels" class="flex items-center gap-2" style="display:none">
            <span id="bindingLabel" class="result-badge"></span>
            <span id="replayLabel" class="result-badge"></span>
          </div>
        </div>
        <div id="verifyAddressBar" class="verify-address-bar" style="display:none">
          <span class="font-mono text-[11px] uppercase tracking-[0.15em] text-[#86efac]/70">Authenticated Account</span>
          <div class="flex flex-col">
            <span id="verifyEnsName" class="font-mono text-[13px] text-[#86efac]" style="display:none"></span>
            <span id="verifyAddress" class="font-mono text-[12px] text-[#86efac]"></span>
          </div>
        </div>
        <div class="relative">
          <pre id="verificationResult" class="max-h-48 overflow-x-auto overflow-y-hidden bg-white/5 p-3 font-mono text-[12px] leading-6 text-white/55 transition-all duration-300">Not sent yet.</pre>
          <button id="toggleVerifyResult" class="mt-2 w-full font-mono text-[11px] uppercase tracking-[0.15em] text-white/40 transition-colors hover:text-white/70" type="button" style="display:none">
            Show more ▼
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .playground-field {
    border: 1px solid rgba(255, 255, 255, 0.25);
    background: transparent;
    padding: 0.65rem 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.86rem;
    color: white;
    transition: border-color 180ms ease;
  }

  .playground-field:focus {
    outline: none;
    border-color: rgba(255, 255, 255, 0.8);
  }

  .playground-field-disabled {
    opacity: 0.55;
    cursor: default;
    border-color: rgba(255, 255, 255, 0.15);
  }

  .playground-field-disabled:focus {
    border-color: rgba(255, 255, 255, 0.15);
  }

  .component-chip {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    line-height: 1.2;
  }

  .component-checkbox {
    accent-color: white;
  }

  .ttl-input {
    width: 4rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: transparent;
    padding: 0.25rem 0.4rem;
    font-family: var(--font-mono);
    font-size: 11px;
    color: white;
    text-align: center;
  }

  .ttl-input:focus {
    outline: none;
    border-color: rgba(255, 255, 255, 0.5);
  }

  .ttl-input::-webkit-outer-spin-button,
  .ttl-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .component-info-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 50%;
    background: transparent;
    color: rgba(255, 255, 255, 0.45);
    font-family: var(--font-mono);
    font-size: 11px;
    cursor: pointer;
    transition: all 180ms ease;
  }

  .component-info-btn:hover {
    color: rgba(255, 255, 255, 0.9);
    border-color: rgba(255, 255, 255, 0.6);
  }

  .component-tooltip {
    display: none;
    position: absolute;
    bottom: calc(100% + 6px);
    right: 0;
    width: 320px;
    padding: 0.75rem 1rem;
    background: #1a1a1a;
    border: 1px solid rgba(255, 255, 255, 0.2);
    font-family: var(--font-mono);
    font-size: 10.5px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    z-index: 10;
  }

  .component-tooltip::after {
    content: "";
    position: absolute;
    top: 100%;
    right: 0;
